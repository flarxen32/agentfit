# --- Offer page (Bet #1) ---
# Where the report card CTA sends visitors. This is the Bet #1 offer page
# (XRO-11) with an intake form that auto-fills from the query params below.
# Local dev: http://localhost:3001  (offer page runs on 3000 in its own repo;
# set this to wherever the offer page is reachable).
# Production: set to the deployed offer page URL.
NEXT_PUBLIC_OFFER_URL=http://localhost:3001

# --- Stripe checkout (FASTEST revenue path) ---
# A Stripe Payment Link URL for the $750 custom agent build. Create one at
# https://dashboard.stripe.com/payment-links — no server-side code needed.
# When set, the /offer page redirects directly to Stripe checkout.
# This is the single fastest way to enable checkout: ~3 minutes to provision.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_URL=

# --- Stripe checkout (server-side, optional) ---
# If you prefer server-side Stripe Checkout sessions instead of Payment Links,
# set STRIPE_SECRET_KEY (server-side only, never prefix with NEXT_PUBLIC_).
# Payment Link above takes precedence if both are set.
# STRIPE_SECRET_KEY=

# --- Analytics ---
# Plausible analytics domain. When set, the Plausible script is included
# and analytics events fire in production. Leave blank for dev (console.debug).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Lead persistence (Vercel KV / Upstash Redis) ---
# Auto-provisioned via the Vercel marketplace (Upstash Redis integration).
# Vercel injects these automatically when the integration is enabled — do NOT
# set them manually unless you are running locally.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Protects the /api/leads export endpoint with HTTP Basic Auth.
# Format: any username/password combo you choose.
LEADS_BASIC_AUTH=xro-leads:agentfit2026

# --- Outbound email (Resend) — XRO-24 ---
# Provisioned in the Resend dashboard. Server-side only; NEVER prefix
# with NEXT_PUBLIC_.
RESEND_API_KEY=
# A Resend-verified sending domain. Resend gives you the DKIM/SPF/return-path
# records to add to your DNS (Cloudflare for xablam.com) before this works.
RESEND_FROM_DOMAIN=hello.xablam.com
# Optional: full From: header. Defaults to "AgentFit <outreach@{RESEND_FROM_DOMAIN}>".
# RESEND_FROM_EMAIL=AgentFit <outreach@hello.xablam.com>
